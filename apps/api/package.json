{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.js",
    "build": "npx prisma generate --schema=./prisma/schema.prisma",
    "start": "npx prisma generate --schema=./prisma/schema.prisma && tsx src/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "npx prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "stripe": "^18.5.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}